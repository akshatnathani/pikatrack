{
  "manifest_version": 3,
  "name": "PikaDex",
  "version": "2.0.0",
  "description": "Your Pokémon productivity companion. Catch websites, earn XP, evolve your partner.",
  "permissions": ["tabs", "storage", "alarms", "scripting", "activeTab"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["http://*/*","https://*/*"], "js": ["content.js"], "run_at": "document_end" },
    { "matches": ["*://leetcode.com/*","*://www.leetcode.com/*"], "js": ["scrapers/leetcode.js"], "run_at": "document_idle" },
    { "matches": ["*://github.com/*"], "js": ["scrapers/github.js"], "run_at": "document_idle" },
    { "matches": ["*://www.youtube.com/*","*://youtube.com/*"], "js": ["scrapers/youtube.js"], "run_at": "document_idle" }
  ],
  "action": { "default_popup": "popup.html", "default_title": "PikaDex" },
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'self'" },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
